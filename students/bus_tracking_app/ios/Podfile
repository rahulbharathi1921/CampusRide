# Podfile for CampusRide
platform :ios, '14.0'

ENV['COCOAPODS_DISABLE_STATS'] = '1'

project 'Runner', {
  'Debug' => :debug,
  'Release' => :release,
  'Profile' => :profile,
}

# 1. Use the environment variable set by flutter-action directly
flutter_root = ENV['FLUTTER_ROOT']

# 2. Fallback to parsing Generated.xcconfig if ENV is not set (for local builds)
if flutter_root.nil? || flutter_root.empty?
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  if File.exist?(generated_xcode_build_settings_path)
    File.foreach(generated_xcode_build_settings_path) do |line|
      matches = line.match(/FLUTTER_ROOT=(.*)/)
      next unless matches
      flutter_root = matches[1].strip.gsub(/\A['"]+|['"]+\z/, "")
      break
    end
  end
end

if flutter_root.nil? || flutter_root.empty?
  raise "FLUTTER_ROOT not found. Run 'flutter pub get' first."
end

# 3. Load the backend script
# Using require with absolute path but no extension is the safest Ruby pattern
backend_path = File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'xcode_backend'), flutter_root)
require backend_path

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Install all pods for the plugin
  flutter_install_all_ios_pods File.expand_path(File.join('..', '..'), __FILE__)
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
    end
  end
end
