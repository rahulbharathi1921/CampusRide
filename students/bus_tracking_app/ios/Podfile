# Podfile for CampusRide
platform :ios, '14.0'

ENV['COCOAPODS_DISABLE_STATS'] = '1'

project 'Runner', {
  'Debug' => :debug,
  'Release' => :release,
  'Profile' => :profile,
}

# 1. Find Generated.xcconfig
generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)

# 2. Get FLUTTER_ROOT
flutter_root = ENV['FLUTTER_ROOT']
if (flutter_root.nil? || flutter_root.empty?) && File.exist?(generated_xcode_build_settings_path)
  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT=(.*)/)
    if matches
      flutter_root = matches[1].strip.gsub(/[ "']/, '')
      break
    end
  end
end

# 3. Fallback to common path if still nil (unlikely on GitHub Actions but good for local)
if flutter_root.nil? || flutter_root.empty?
  raise "FLUTTER_ROOT not found. Run 'flutter pub get' first."
end

# 4. Load xcode_backend.rb
# Using a more direct approach to avoid path expansion issues
xcode_backend_path = File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'xcode_backend.rb')
unless File.exist?(xcode_backend_path)
  raise "Could not find xcode_backend.rb at #{xcode_backend_path}"
end
require xcode_backend_path

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Pass the absolute path to the project root
  project_root = File.expand_path(File.join('..', '..'), __FILE__)
  flutter_install_all_ios_pods(project_root)
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
    end
  end
end
