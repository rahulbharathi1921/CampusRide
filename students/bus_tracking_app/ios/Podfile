# Podfile for CampusRide
platform :ios, '14.0'

ENV['COCOAPODS_DISABLE_STATS'] = '1'

project 'Runner', {
  'Debug' => :debug,
  'Release' => :release,
  'Profile' => :profile,
}

# 1. Standard Ruby script to find Flutter Root from Generated.xcconfig
# This is the industry standard way that works on local and CI
def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    # Look for FLUTTER_ROOT= with or without spaces/quotes
    if line =~ /FLUTTER_ROOT\s*=\s*(.*)/
      return $1.strip.gsub(/\A['"]+|['"]+\z/, "")
    end
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}"
end

# 2. Load the backend
load File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'xcode_backend.rb')

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.expand_path(File.join('..', '..'), __FILE__)
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
    end
  end
end
